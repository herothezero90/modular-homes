---
import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
			<meta
				name="description"
				data-i18n-content="meta.description"
				content="Thoughtfully designed modular homes, built with precision and delivered in weeks."
			/>
		<title>Modular Homes | Built for life</title>
		<link rel="icon" type="image/svg+xml" href="/media/icon.svg" />
		<link rel="preload" as="image" href="/media/generated/hero-forest.jpg" fetchpriority="high" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cal+Sans&family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500;1,600&family=Montserrat:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<script is:inline>
			if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
				document.documentElement.classList.add("has-scroll-animations");
				window.setTimeout(() => document.documentElement.classList.remove("has-scroll-animations"), 3000);
			}
		</script>
	</head>

	<body>
		<header class="hero-wrap" id="home">
			<div class="hero-card">
				<img
					class="hero-image"
					src="/media/generated/hero-forest.jpg"
						alt="Contemporary dark timber modular home in a forest clearing"
						data-i18n-alt="images.hero"
						data-animation="hero-parallax"
						fetchpriority="high"
					/>
				<div class="hero-overlay"></div>

				<div class="hero-topbar">
					<a class="brand brand-light" href="#home" aria-label="Modular Homes home" data-i18n-aria-label="brandHome">
						<svg class="brand-mark" viewBox="0 0 24 24" aria-hidden="true">
							<path d="M12 2v20M2 12h20M4.93 4.93l14.14 14.14M19.07 4.93 4.93 19.07" />
						</svg>
						<span data-i18n="brand">Modular Homes</span>
					</a>
					<button
						class="menu-toggle"
						type="button"
						aria-expanded="false"
						aria-controls="hero-menu"
						aria-label="Open menu"
						data-menu-toggle
					>
						<span></span>
						<span></span>
						<span></span>
					</button>
					<div class="hero-controls" id="hero-menu">
						<nav class="hero-nav" aria-label="Primary navigation" data-i18n-aria-label="nav.aria">
							<a href="#about" data-i18n="nav.about">About</a>
							<a href="#process" data-i18n="nav.process">Process</a>
							<a href="#projects" data-i18n="nav.projects">Projects</a>
							<a href="#benefits" data-i18n="nav.benefits">Benefits</a>
							<a class="nav-cta" href="#contact" data-i18n="nav.startProject">Start a project</a>
						</nav>
						<div class="language-switcher language-switcher-desktop" aria-label="Language" data-i18n-aria-label="language.aria">
							<button class="is-active" type="button" data-language="en" aria-pressed="true">EN</button>
							<span aria-hidden="true">/</span>
							<button type="button" data-language="hr" aria-pressed="false">HR</button>
						</div>
					</div>
				</div>

				<div class="hero-copy">
					<h1>
						<span data-i18n="hero.title">Naturally considered homes,</span>
						<span class="title-accent" data-i18n="hero.titleAccent">made for living.</span>
					</h1>
					<p class="hero-lead" data-i18n="hero.lead">
						From first sketch to finished space, we create calm, sustainable homes that
						arrive in weeks, not months.
					</p>
					<div class="language-switcher language-switcher-mobile" aria-label="Language" data-i18n-aria-label="language.aria">
						<button class="is-active" type="button" data-language="en" aria-pressed="true">EN</button>
						<span aria-hidden="true">/</span>
						<button type="button" data-language="hr" aria-pressed="false">HR</button>
					</div>
				</div>
				</div>
			</header>

		<main>
			<section class="intro section" id="about">
				<div class="container">
					<div class="intro-heading" data-animation="heading">
						<h2 data-i18n="about.title">Building a home should feel as clear as the space itself.</h2>
					</div>

					<div class="story-grid" data-animation-group="story">
						<div class="story-copy">
							<p data-i18n="about.paragraph1">
								We design modular homes where simplicity and performance are inseparable.
								Every decision is shaped by how the space will feel, age and adapt to
								everyday life.
							</p>
							<p data-i18n="about.paragraph2">
								Our homes are manufactured in controlled conditions, then assembled on
								site with less disruption, less waste and a more predictable path to
								moving day.
							</p>
							<a class="text-link" href="#benefits"><span data-i18n="about.link">Why modular</span> <i class="link-plus" data-lucide="plus" aria-hidden="true"></i></a>
						</div>

						<figure class="story-small-image" data-animation="image-parallax" data-parallax-distance="24">
							<img
								src="/media/generated/forest-studio.jpg"
								alt="Small modular garden studio among trees at dusk"
								data-i18n-alt="images.forestStudio"
							/>
						</figure>

						<figure class="story-main-image" data-animation="image-parallax" data-parallax-distance="42">
							<img
								src="/media/generated/terrace-detail.jpg"
								alt="Warm covered terrace and interior of a modular home"
								data-i18n-alt="images.terrace"
							/>
						</figure>
					</div>
				</div>
			</section>

			<section class="values section" id="benefits">
				<div class="container">
					<div class="section-heading section-heading-split" data-animation="heading">
						<div>
							<h2><span data-i18n="benefits.title">More control.</span><br /><span class="title-accent" data-i18n="benefits.titleAccent">Less compromise.</span></h2>
						</div>
						<p data-i18n="benefits.lead">
							A considered way to build: practical, efficient and grounded in the
							qualities that make a house feel like home.
						</p>
					</div>

					<div class="value-grid" data-animation-group="cards">
							<article class="value-card">
								<p class="card-number">01</p>
								<h3 data-i18n="benefits.cards.0.title">Faster by design</h3>
								<p data-i18n="benefits.cards.0.body">
									Factory production and site preparation happen in parallel, trimming
									months from a conventional build.
							</p>
						</article>
							<article class="value-card">
								<p class="card-number">02</p>
								<h3 data-i18n="benefits.cards.1.title">Built with precision</h3>
								<p data-i18n="benefits.cards.1.body">
									Controlled conditions mean consistent details, fewer surprises and a
									cleaner construction site.
							</p>
						</article>
							<article class="value-card">
								<p class="card-number">03</p>
								<h3 data-i18n="benefits.cards.2.title">Lighter footprint</h3>
								<p data-i18n="benefits.cards.2.body">
									Smarter material use, efficient envelopes and less on-site waste reduce
									the impact of every home.
							</p>
						</article>
					</div>
				</div>
			</section>

			<section class="process section" id="process">
				<div class="container">
					<div class="process-intro" data-animation="heading">
						<h2 data-i18n="process.title">A clear process, from the first idea to your front door.</h2>
					</div>

					<div class="process-grid" data-animation-group="process">
						<article class="process-card">
							<img
								src="/media/generated/meadow-home.jpg"
								alt="Timber modular family home in a meadow"
								data-i18n-alt="images.meadowHome"
							/>
							<p class="process-number">01</p>
							<h3 data-i18n="process.cards.0.title">Shape the brief</h3>
							<p data-i18n="process.cards.0.body">
								We start with your site, budget and daily rhythms to create a home that
								fits naturally into your life.
							</p>
							<a class="text-link" href="#contact"><span data-i18n="process.cards.0.link">Start a conversation</span> <i class="link-plus" data-lucide="plus" aria-hidden="true"></i></a>
						</article>

						<article class="process-card">
							<img
								src="/media/generated/assembly-site.jpg"
								alt="Timber wall module being installed on a prepared foundation"
								data-i18n-alt="images.assembly"
							/>
							<p class="process-number">02</p>
							<h3 data-i18n="process.cards.1.title">Build with precision</h3>
							<p data-i18n="process.cards.1.body">
								Your home is crafted off site while groundwork is prepared, with every
								detail checked before delivery.
							</p>
							<a class="text-link" href="#contact"><span data-i18n="process.cards.1.link">Explore the process</span> <i class="link-plus" data-lucide="plus" aria-hidden="true"></i></a>
						</article>

						<article class="process-card">
							<img
								src="/media/generated/courtyard-home.jpg"
								alt="Completed green modular courtyard home with an olive tree"
								data-i18n-alt="images.courtyard"
							/>
							<p class="process-number">03</p>
							<h3 data-i18n="process.cards.2.title">Settle in sooner</h3>
							<p data-i18n="process.cards.2.body">
								Modules arrive ready for a focused on-site assembly, so the final steps
								feel organized and predictable.
							</p>
							<a class="text-link" href="#contact"><span data-i18n="process.cards.2.link">Plan your home</span> <i class="link-plus" data-lucide="plus" aria-hidden="true"></i></a>
						</article>
					</div>
				</div>
			</section>

			<section class="projects section" id="projects">
				<div class="container">
					<div class="section-heading section-heading-split projects-heading" data-animation="heading">
						<div>
							<h2 data-i18n="projects.title">Spaces with a quieter kind of confidence.</h2>
						</div>
						<a class="button button-dark" href="#contact" data-i18n="projects.link">Discuss your project</a>
					</div>

					<div class="projects-grid" data-animation-group="projects">
							<button class="project-card project-card-large" type="button" data-open-project="0">
								<img src="/media/generated/lake-cabin.jpg" alt="Compact timber modular cabin by a lake" data-i18n-alt="images.lakeCabin" />
								<div class="project-meta">
									<div>
										<p data-i18n="projects.cards.0.title">Lake cabin</p>
										<span data-i18n="projects.cards.0.meta">Compact retreat / 42 m²</span>
								</div>
								<span class="project-arrow"><i data-lucide="plus" aria-hidden="true"></i></span>
							</div>
						</button>

						<button class="project-card" type="button" data-open-project="1">
							<img
									src="/media/generated/coastal-villa.jpg"
									alt="Pale modular villa overlooking the Adriatic coast"
									data-i18n-alt="images.coastalVilla"
								/>
								<div class="project-meta">
									<div>
										<p data-i18n="projects.cards.1.title">Coastal home</p>
										<span data-i18n="projects.cards.1.meta">Family villa / 118 m²</span>
								</div>
								<span class="project-arrow"><i data-lucide="plus" aria-hidden="true"></i></span>
							</div>
						</button>

						<button class="project-card" type="button" data-open-project="2">
							<img
									src="/media/generated/forest-studio.jpg"
									alt="Dark timber modular studio in a wooded garden"
									data-i18n-alt="images.forestStudioProject"
								/>
								<div class="project-meta">
									<div>
										<p data-i18n="projects.cards.2.title">Forest studio</p>
										<span data-i18n="projects.cards.2.meta">Garden room / 24 m²</span>
								</div>
								<span class="project-arrow"><i data-lucide="plus" aria-hidden="true"></i></span>
							</div>
						</button>

						<button class="project-card project-card-wide" type="button" data-open-project="3">
							<img
									src="/media/generated/hero-forest.jpg"
									alt="Dark timber modular home with large windows in a forest clearing"
									data-i18n-alt="images.woodlandPavilion"
								/>
								<div class="project-meta">
									<div>
										<p data-i18n="projects.cards.3.title">Woodland pavilion</p>
										<span data-i18n="projects.cards.3.meta">Two-bedroom home / 96 m²</span>
								</div>
								<span class="project-arrow"><i data-lucide="plus" aria-hidden="true"></i></span>
							</div>
						</button>
					</div>
				</div>
			</section>

			<section class="statement section">
				<div class="container">
					<div class="statement-card" data-animation="statement">
						<h2 data-i18n="statement.title">
							“Thoughtful architecture, controlled construction and a home that feels
							entirely your own.”
						</h2>

						<div class="stats-grid" data-animation-group="stats">
							<div>
								<strong>3–4</strong>
								<span data-i18n="statement.stats.0">weeks for on-site assembly</span>
							</div>
							<div>
								<strong>30%</strong>
								<span data-i18n="statement.stats.1">less material waste</span>
							</div>
							<div>
								<strong>A+</strong>
								<span data-i18n="statement.stats.2">energy-conscious envelope</span>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section class="contact section" id="contact">
				<div class="container contact-grid">
					<div class="contact-copy" data-animation="contact-left">
						<h2 data-i18n="contact.title">Ready to make space for what matters?</h2>
						<p data-i18n="contact.lead">
							Tell us where you want to build and how you want to live. We will help turn
							that first idea into a clear plan.
						</p>
						<div class="contact-actions">
							<button class="button button-accent" type="button" data-open-modal="enquiry" data-i18n="contact.emailAction">Send an enquiry</button>
							<button class="button button-outline" type="button" data-open-modal="booking" data-i18n="contact.callAction">Book a call</button>
						</div>
						<div class="contact-details">
							<p><span>Email</span> hello@modular</p>
							<p><span data-i18n="contact.studioLabel">Studio</span> <span class="contact-detail-value" data-i18n="contact.studioLocation">Zagreb, Croatia</span></p>
						</div>
					</div>

					<img
						class="contact-image"
						src="/media/generated/coastal-villa.jpg"
						alt="Modular villa set into a Mediterranean coastal landscape"
						data-i18n-alt="images.contact"
						data-animation="contact-right"
					/>
				</div>
			</section>
		</main>

		<footer>
			<div class="container footer-grid" data-animation-group="footer">
				<div>
					<a class="brand brand-light" href="#home">
						<svg class="brand-mark" viewBox="0 0 24 24" aria-hidden="true">
							<path d="M12 2v20M2 12h20M4.93 4.93l14.14 14.14M19.07 4.93 4.93 19.07" />
						</svg>
						<span data-i18n="brand">Modular Homes</span>
					</a>
					<p data-i18n="footer.tagline">Calm spaces. Precise construction.</p>
				</div>
				<div class="footer-links">
					<a href="#about" data-i18n="nav.about">About</a>
					<a href="#process" data-i18n="nav.process">Process</a>
					<a href="#projects" data-i18n="nav.projects">Projects</a>
					<a href="#contact" data-i18n="nav.contact">Contact</a>
				</div>
				<p class="footer-copy" data-i18n="footer.copyright">© 2026 Horizon</p>
			</div>
		</footer>
		<button class="back-to-top" type="button" aria-label="Back to top" data-back-to-top data-i18n-aria-label="backToTop">
			<span aria-hidden="true">↑</span>
			<span data-i18n="backToTop">Back to top</span>
		</button>

		<div class="modal-layer" data-modal="enquiry" aria-hidden="true">
			<div class="modal-backdrop" data-close-modal></div>
			<section class="modal-card modal-card-enquiry" role="dialog" aria-modal="true" aria-labelledby="enquiry-title">
				<button class="modal-close" type="button" data-close-modal aria-label="Close" data-i18n-aria-label="modal.close">×</button>
				<div class="modal-intro">
					<span class="modal-kicker" data-i18n="enquiry.kicker">Project enquiry</span>
					<h2 id="enquiry-title" data-i18n="enquiry.title">Tell us about the home you have in mind.</h2>
					<p data-i18n="enquiry.lead">A few practical details are enough to start. This showcase form will not send your information anywhere.</p>
				</div>
				<form class="modal-form" data-showcase-form="enquiry">
					<div class="form-grid">
						<label>
							<span data-i18n="enquiry.name">Your name</span>
							<input type="text" name="name" required autocomplete="name" />
						</label>
						<label>
							<span data-i18n="enquiry.email">Email address</span>
							<input type="email" name="email" required autocomplete="email" />
						</label>
						<label>
							<span data-i18n="enquiry.location">Build location</span>
							<input type="text" name="location" required />
						</label>
						<label>
							<span data-i18n="enquiry.budget">Estimated budget</span>
							<select name="budget" required>
								<option value="" data-i18n="enquiry.selectBudget">Select a range</option>
								<option>€150k – €250k</option>
								<option>€250k – €400k</option>
								<option>€400k – €600k</option>
								<option>€600k+</option>
							</select>
						</label>
						<label class="form-field-wide">
							<span data-i18n="enquiry.message">What should we know?</span>
							<textarea name="message" rows="4" required data-i18n-placeholder="enquiry.messagePlaceholder" placeholder="Size, rooms, site details or the feeling you want to create..."></textarea>
						</label>
					</div>
					<div class="modal-form-footer">
						<p data-i18n="modal.showcaseNote">Showcase mode · No information is sent or stored.</p>
						<button class="button button-dark" type="submit" data-i18n="enquiry.submit">Send project brief</button>
					</div>
				</form>
				<div class="modal-success" data-modal-success hidden>
					<span class="success-mark">✓</span>
					<h3 data-i18n="enquiry.successTitle">Your project brief is ready.</h3>
					<p data-i18n="enquiry.successBody">Thanks for sharing the first details. In a live version, our studio would reply within two working days.</p>
					<button class="button button-dark" type="button" data-close-modal data-i18n="modal.done">Done</button>
				</div>
			</section>
		</div>

		<div class="modal-layer" data-modal="booking" aria-hidden="true">
			<div class="modal-backdrop" data-close-modal></div>
			<section class="modal-card modal-card-booking" role="dialog" aria-modal="true" aria-labelledby="booking-title">
				<button class="modal-close" type="button" data-close-modal aria-label="Close" data-i18n-aria-label="modal.close">×</button>
				<div class="modal-intro">
					<span class="modal-kicker" data-i18n="booking.kicker">Introductory call</span>
					<h2 id="booking-title" data-i18n="booking.title">Choose a time that works for you.</h2>
					<p data-i18n="booking.lead">A relaxed 30-minute call to discuss your site, priorities and next practical steps.</p>
				</div>
				<form class="booking-layout" data-showcase-form="booking">
					<div class="booking-calendar">
						<div class="booking-calendar-head">
							<button type="button" aria-label="Previous week" data-booking-previous>←</button>
							<strong data-booking-month>June 2026</strong>
							<button type="button" aria-label="Next week" data-booking-next>→</button>
						</div>
						<div class="booking-dates" data-booking-dates></div>
						<div class="booking-legend">
							<span><i></i><span data-i18n="booking.available">Available</span></span>
							<span><i class="is-booked"></i><span data-i18n="booking.booked">Booked</span></span>
						</div>
					</div>
					<div class="booking-times">
						<p class="booking-date-label" data-booking-date-label></p>
						<div class="time-slots" data-time-slots></div>
						<div class="modal-form-footer">
							<p data-i18n="modal.showcaseNote">Showcase mode · No information is sent or stored.</p>
							<button class="button button-dark" type="submit" disabled data-booking-submit data-i18n="booking.submit">Confirm call</button>
						</div>
					</div>
				</form>
				<div class="modal-success" data-modal-success hidden>
					<span class="success-mark">✓</span>
					<h3 data-i18n="booking.successTitle">Your call is reserved.</h3>
					<p><span data-i18n="booking.successBody">We have held</span> <strong data-booking-confirmation></strong>. <span data-i18n="booking.successEnd">In a live version, a calendar invitation would be on its way.</span></p>
					<button class="button button-dark" type="button" data-close-modal data-i18n="modal.done">Done</button>
				</div>
			</section>
		</div>

		<div class="modal-layer" data-modal="project" aria-hidden="true">
			<div class="modal-backdrop" data-close-modal></div>
			<section class="modal-card modal-card-project" role="dialog" aria-modal="true" aria-labelledby="project-modal-title">
				<button class="modal-close modal-close-on-image" type="button" data-close-modal aria-label="Close" data-i18n-aria-label="modal.close">×</button>
				<div class="project-modal-image-wrap">
					<img data-project-modal-image src="/media/generated/lake-cabin.jpg" alt="" />
					<span class="project-modal-index" data-project-modal-index>01 / 04</span>
				</div>
				<div class="project-modal-content">
					<div class="project-modal-heading">
						<div>
							<span class="modal-kicker" data-project-modal-type>Compact retreat</span>
							<h2 id="project-modal-title" data-project-modal-title>Lake cabin</h2>
						</div>
						<p data-project-modal-description></p>
					</div>
					<div class="project-specs">
						<div><span data-i18n="projectModal.location">Location</span><strong data-project-modal-location></strong></div>
						<div><span data-i18n="projectModal.area">Area</span><strong data-project-modal-area></strong></div>
						<div><span data-i18n="projectModal.bedrooms">Bedrooms</span><strong data-project-modal-bedrooms></strong></div>
						<div><span data-i18n="projectModal.status">Status</span><strong data-project-modal-status></strong></div>
					</div>
					<div class="project-modal-bottom">
						<div>
							<span class="project-features-label" data-i18n="projectModal.features">Key features</span>
							<div class="project-features" data-project-modal-features></div>
						</div>
